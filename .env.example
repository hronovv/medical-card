# Copy to .env
PORT=8080

# Docker Compose app service: DB_HOST=postgres
# Локально make dev-api всегда использует localhost (см. Makefile)
# Миграции: make migrate-up DB_HOST=localhost
DB_HOST=postgres
DB_PORT=5432
DB_NAME=medical_card
DB_USER=medical
DB_PASSWORD=password1234
DB_SCHEMA=public

# Redis (сессии)
# Docker Compose: REDIS_HOST=redis
# Локально make dev-api: redis на localhost
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
SESSION_TTL=24h
